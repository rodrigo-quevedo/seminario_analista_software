{
  "name": "servidor_backend",
  "version": "1.0.0",
  "main": "dist/server.js",
  "scripts": {
    "dev": "node scripts/updatePathsAliases/updatePathsAliases.js && node --env-file=.env -r ts-node/register src/server.ts",
    "build": "node scripts/updatePathsAliases/updatePathsAliases.js && tsc",
    "start": "node --env-file=.env dist/server.js"
  },
  "keywords": [],
  "author": "Quevedo, Rodrigo Martín (https://github.com/rodrigo-quevedo)",
  "license": "MIT",
  "description": "Backend server API",
  "dependencies": {
    "express": "^5.1.0",
    "module-alias": "^2.2.3",
    "mongoose": "^8.17.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/node": "^24.0.13",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3"
  },
  "_moduleAliases": {
    "@controllers": "./src/controllers",
    "@routes": "./src/routes",
    "@middlewares": "./src/middlewares",
    "@customTypes": "./src/types",
    "@utils": "./src/utils",
    "@validations": "./src/validations",
    "@errors": "./src/errors",
    "@config": "./src/config",
    "@models": "./src/models",
    "@daos": "./src/DAOs",
    "@services": "./src/services"
  }
}